{
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard_env.sh"
          }
        ]
      }
    ]
  }
}
