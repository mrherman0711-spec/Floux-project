<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Floux recupera las llamadas perdidas de tu salón de estética en Madrid. Tu cliente recibe un WhatsApp en 30 segundos. Sin apps. Sin contratos. Desde €47/mes." />
  <title>Floux Madrid — Recupera los Clientes que Pierdes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Cormorant+SC:wght@400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black:   #000000;
      --charcoal:#1A1714;
      --charcoal2:#231F1B;
      --cream:   #F2EDE6;
      --white:   #FFFFFF;
      --gold:    #9A7B4F;
      --gold-h:  #7D6340;
      --light:   #DED8D0;
      --body:    #6B6560;
      --serif:   'Cormorant Garamond', Georgia, serif;
      --serif-sc:'Cormorant SC', Georgia, serif;
      --sans:    'Inter', 'Helvetica Neue', Arial, sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: var(--black); color: var(--white); line-height: 1.7; -webkit-font-smoothing: antialiased; }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }

    /* Typography */
    h1, h2, h3 { font-family: var(--serif); font-weight: 300; line-height: 1.08; letter-spacing: 0.02em; }
    h1 { font-size: clamp(3.5rem, 8vw, 7rem); letter-spacing: 0.01em; }
    h2 { font-size: clamp(2rem, 4vw, 3.5rem); letter-spacing: 0.12em; text-transform: uppercase; font-family: var(--serif-sc); }
    h3 { font-size: clamp(1.1rem, 1.8vw, 1.4rem); letter-spacing: 0.05em; font-family: var(--serif-sc); text-transform: uppercase; }
    p { color: rgba(255,255,255,0.65); font-size: 1rem; font-weight: 300; line-height: 1.85; }
    .eyebrow { display: block; font-size: 0.6875rem; font-weight: 400; letter-spacing: 0.32em; text-transform: uppercase; color: var(--gold); font-family: var(--sans); }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 40px; }
    section { padding: 120px 0; }

    /* Buttons — Four Seasons style: outlined, zero-radius, wide tracking */
    .btn { display: inline-block; font-family: var(--sans); font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; padding: 16px 44px; border-radius: 0; cursor: pointer; transition: background .3s, color .3s, border-color .3s; border: 1px solid transparent; }
    .btn-primary { background: transparent; color: var(--white); border-color: var(--white); }
    .btn-primary:hover { background: var(--white); color: var(--black); }
    .btn-gold { background: transparent; color: var(--gold); border-color: var(--gold); }
    .btn-gold:hover { background: var(--gold); color: var(--black); }
    .btn-filled { background: var(--white); color: var(--black); border-color: var(--white); }
    .btn-filled:hover { background: transparent; color: var(--white); }

    /* ── HEADER ────────────────────────────────────────────── */
    #header {
      position: fixed; inset: 0 0 auto 0; z-index: 100;
      background: linear-gradient(to bottom, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0) 100%);
      transition: background .4s ease, border-color .4s ease;
    }
    #header.scrolled {
      background: var(--black);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    nav {
      display: flex; align-items: center; justify-content: space-between;
      height: 80px; max-width: 1400px; margin: 0 auto; padding: 0 48px;
    }
    .logo {
      font-family: var(--serif); font-size: 1.5rem; font-weight: 400;
      color: var(--white); letter-spacing: 0.08em;
    }
    .logo em { font-style: normal; color: var(--gold); }
    .nav-links { display: flex; align-items: center; gap: 44px; }
    .nav-links a {
      font-size: 0.625rem; font-weight: 500; letter-spacing: 0.2em;
      text-transform: uppercase; color: rgba(255,255,255,0.6); transition: color .2s;
    }
    .nav-links a:hover { color: var(--white); }
    .nav-links .btn { margin-left: 8px; padding: 11px 28px; font-size: 0.625rem; }

    /* Burger */
    .burger { display:none; flex-direction:column; justify-content:center; gap:5px; width:36px; height:36px; background:none; border:none; cursor:pointer; padding:4px; }
    .burger span { display:block; width:22px; height:1px; background:var(--white); transition:transform .3s, opacity .3s; }
    .burger.open span:nth-child(1) { transform:translateY(6.5px) rotate(45deg); }
    .burger.open span:nth-child(2) { opacity:0; }
    .burger.open span:nth-child(3) { transform:translateY(-6.5px) rotate(-45deg); }
    .mobile-drawer { display:none; position:fixed; top:80px; left:0; right:0; background:var(--black); border-bottom:1px solid rgba(255,255,255,0.08); padding:16px 40px 32px; flex-direction:column; gap:4px; z-index:99; }
    .mobile-drawer.open { display:flex; }
    .mobile-drawer a { font-size:0.625rem; font-weight:500; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.6); padding:15px 0; border-bottom:1px solid rgba(255,255,255,0.07); transition:color .2s; }
    .mobile-drawer a:last-of-type { border-bottom:none; }
    .mobile-drawer a:hover { color:var(--white); }
    .mobile-drawer .btn { margin-top:14px; text-align:center; border-bottom:none !important; }
    @media (max-width: 960px) { .nav-links { display:none; } .burger { display:flex; } }

    /* ── HERO ──────────────────────────────────────────────── */
    #hero { position:relative; height:100vh; min-height:700px; padding:0; overflow:hidden; }
    .hero-img { position:absolute; inset:0; }
    .hero-img img {
      width:100%; height:100%; object-fit:cover; object-position:60% center;
      transform: scale(1.06);
      animation: heroZoom 12s ease-out forwards;
    }
    @keyframes heroZoom {
      from { transform: scale(1.06); }
      to   { transform: scale(1.0); }
    }
    .hero-img::after {
      content:''; position:absolute; inset:0;
      background: linear-gradient(
        to top,
        rgba(0,0,0,0.92) 0%,
        rgba(0,0,0,0.45) 45%,
        rgba(0,0,0,0.15) 100%
      );
    }
    /* Thin top bar like Four Seasons */
    .hero-topbar {
      position:absolute; top:80px; left:0; right:0; z-index:3;
      display:flex; justify-content:center;
      padding:14px 48px;
      border-bottom: 1px solid rgba(255,255,255,0.12);
      font-size:0.625rem; font-weight:500; letter-spacing:0.22em; text-transform:uppercase;
      color:rgba(255,255,255,0.55);
    }
    .hero-topbar span { margin:0 20px; }

    .hero-copy {
      position:absolute; bottom:0; left:0; right:0; padding:0 48px 100px;
      max-width:1400px; margin:0 auto; z-index:2;
    }
    .hero-copy .eyebrow { margin-bottom:24px; color:rgba(255,255,255,0.6); }
    .hero-copy h1 {
      color:var(--white); margin-bottom:0; max-width:820px;
      font-weight:300; text-transform:uppercase; letter-spacing:0.03em;
      font-size: clamp(3rem, 6vw, 5.5rem);
      animation: heroFade 1.2s ease-out 0.3s both;
    }
    .hero-copy h1 em { font-style:italic; text-transform:none; color:var(--white); }
    @keyframes heroFade {
      from { opacity:0; transform:translateY(30px); }
      to   { opacity:1; transform:translateY(0); }
    }

    /* Scroll indicator — FS style */
    .hero-scroll {
      position:absolute; bottom:32px; right:48px; z-index:3;
      display:flex; align-items:center; gap:12px;
      font-size:0.5625rem; letter-spacing:0.28em; text-transform:uppercase;
      color:rgba(255,255,255,0.45); writing-mode:vertical-rl;
      animation: heroFade 1.4s ease-out 0.8s both;
    }
    .hero-scroll::before {
      content:''; display:block; width:1px; height:48px;
      background:rgba(255,255,255,0.35);
      animation: lineGrow 1.5s ease-out 1s both;
    }
    @keyframes lineGrow {
      from { height:0; }
      to   { height:48px; }
    }

    .hero-btns {
      display:flex; gap:16px; flex-wrap:wrap;
      margin-top:40px;
      animation: heroFade 1.2s ease-out 0.6s both;
    }

    /* ── SCROLL REVEAL ─────────────────────────────────────── */
    .reveal { opacity:0; transform:translateY(40px); transition:opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1); }
    .reveal.visible { opacity:1; transform:translateY(0); }
    .reveal-delay-1 { transition-delay:0.12s; }
    .reveal-delay-2 { transition-delay:0.24s; }
    .reveal-delay-3 { transition-delay:0.36s; }
    .reveal-delay-4 { transition-delay:0.48s; }

    /* ── IMAGE EFFECTS ─────────────────────────────────────── */
    .img-zoom { overflow:hidden; }
    .img-zoom img { transition:transform 1.1s cubic-bezier(0.16,1,0.3,1), filter 1.1s ease; filter:brightness(0.82) saturate(0.85); }
    .img-zoom:hover img { transform:scale(1.05); filter:brightness(0.92) saturate(1.0); }

    /* Divider line gold */
    .gold-divider { width:36px; height:1px; background:var(--gold); margin:20px auto 0; }
    .gold-divider-left { width:36px; height:1px; background:var(--gold); margin:20px 0 0; }

    /* ── SECTION: COMO (Process) ───────────────────────────── */
    #como { background:var(--charcoal); }
    .process-grid {
      display:grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap:2px;
      margin-top:80px;
    }
    .process-card {
      position:relative; overflow:hidden;
      aspect-ratio:4/3;
      cursor:default;
    }
    .process-card img {
      width:100%; height:100%; object-fit:cover;
      transition:transform 1.2s cubic-bezier(0.16,1,0.3,1), filter 1.2s ease;
      filter:brightness(0.55) saturate(0.7);
    }
    .process-card:hover img {
      transform:scale(1.06);
      filter:brightness(0.65) saturate(0.85);
    }
    .process-card-overlay {
      position:absolute; inset:0;
      background:linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 55%, transparent 100%);
      display:flex; flex-direction:column; justify-content:flex-end;
      padding:40px 36px;
    }
    .process-num {
      font-family:var(--serif-sc); font-size:0.875rem; color:var(--gold);
      letter-spacing:0.2em; margin-bottom:16px;
    }
    .process-card h3 {
      color:var(--white); font-size:1.5rem; text-transform:none;
      letter-spacing:0.02em; font-family:var(--serif); font-weight:300;
      margin-bottom:12px; line-height:1.2;
    }
    .process-card p { font-size:0.875rem; color:rgba(255,255,255,0.65); line-height:1.7; }
    .process-arrow {
      position:absolute; top:50%; right:0; transform:translateY(-50%);
      width:2px; height:2px;
      color:rgba(255,255,255,0.2); font-size:1rem;
      display:flex; align-items:center; justify-content:center;
    }

    /* ── SECTION: STATEMENT (like FS "LA HISTORIA") ───────── */
    #statement {
      background:var(--black);
      text-align:center;
      padding:160px 0;
    }
    #statement h2 {
      font-size:clamp(2rem,3.5vw,3rem);
      color:var(--white); letter-spacing:0.16em;
      max-width:800px; margin:0 auto 32px;
      line-height:1.15;
    }
    #statement p {
      max-width:560px; margin:0 auto 48px;
      color:rgba(255,255,255,0.6);
      font-size:1.0625rem; line-height:1.9;
    }

    /* ── SECTION: PRECIOS ─────────────────────────────────── */
    #precios { background:var(--charcoal); }
    .pricing-grid {
      display:grid; grid-template-columns:repeat(3,1fr);
      gap:1px; background:rgba(255,255,255,0.07);
      margin-top:72px;
    }
    .pricing-card {
      background:var(--black); padding:56px 40px;
      position:relative; transition:background .3s;
    }
    .pricing-card:hover { background:#0a0a0a; }
    .pricing-card.featured { background:var(--charcoal2); }
    .pricing-card.featured:hover { background:#1e1a17; }
    .plan-badge {
      position:absolute; top:0; left:0; right:0;
      background:var(--gold); color:var(--black);
      font-size:0.5625rem; font-weight:600; letter-spacing:0.22em; text-transform:uppercase;
      text-align:center; padding:6px 0;
    }
    .plan-name { font-family:var(--serif-sc); font-size:0.75rem; letter-spacing:0.32em; text-transform:uppercase; color:var(--gold); }
    .plan-price {
      font-family:var(--serif); font-size:4rem; font-weight:300;
      color:var(--white); line-height:1; margin:24px 0 4px;
    }
    .plan-price span { font-size:1rem; color:rgba(255,255,255,0.4); }
    .plan-sub { font-size:0.75rem; color:rgba(255,255,255,0.4); letter-spacing:0.08em; margin-bottom:32px; }
    .plan-divider { width:100%; height:1px; background:rgba(255,255,255,0.08); margin-bottom:32px; }
    .plan-features { display:flex; flex-direction:column; gap:12px; margin-bottom:40px; }
    .plan-features li { font-size:0.875rem; color:rgba(255,255,255,0.72); line-height:1.5; }
    .plan-features li.dim { color:rgba(255,255,255,0.3); }

    /* ── SECTION: PORQUE ─────────────────────────────────── */
    #porque { background:var(--black); }
    .porque-grid {
      display:grid; grid-template-columns:1fr 1fr;
      gap:2px; margin-top:80px;
    }
    .porque-card {
      position:relative; overflow:hidden; aspect-ratio:4/3;
    }
    .porque-card img {
      width:100%; height:100%; object-fit:cover;
      filter:brightness(0.5) saturate(0.7);
      transition:transform 1.1s cubic-bezier(0.16,1,0.3,1), filter 1.1s;
    }
    .porque-card:hover img { transform:scale(1.05); filter:brightness(0.6) saturate(0.85); }
    .porque-card-overlay {
      position:absolute; inset:0;
      background:linear-gradient(to top, rgba(0,0,0,0.88) 0%, transparent 60%);
      padding:40px;
      display:flex; flex-direction:column; justify-content:flex-end;
    }
    .porque-card h3 {
      color:var(--white); font-size:1.5rem; font-family:var(--serif);
      font-weight:300; text-transform:none; letter-spacing:0.01em;
      margin-bottom:10px; line-height:1.2;
    }
    .porque-card p { font-size:0.875rem; color:rgba(255,255,255,0.62); line-height:1.65; }

    /* ── SECTION: HISTORIA ─────────────────────────────────── */
    #historia { background:var(--charcoal); }
    .historia-grid {
      display:grid; grid-template-columns:1fr 1fr;
      gap:100px; align-items:center;
    }
    .historia-img {
      position:relative; overflow:hidden;
      height:600px;
    }
    .historia-img img { width:100%; height:100%; object-fit:cover; filter:brightness(0.85) saturate(0.85); transition:transform 1.2s ease, filter 1.2s ease; }
    .historia-img:hover img { transform:scale(1.03); filter:brightness(0.9) saturate(0.95); }
    .historia-img::before {
      content:''; position:absolute; inset:0; z-index:1;
      background:linear-gradient(135deg, rgba(154,123,79,0.1) 0%, transparent 60%);
      pointer-events:none;
    }
    .stats-row { display:flex; gap:48px; padding-top:40px; border-top:1px solid rgba(255,255,255,0.08); margin-top:40px; }
    .stat-val { font-family:var(--serif); font-size:2.75rem; font-weight:300; color:var(--gold); line-height:1; }
    .stat-label { font-size:0.6875rem; color:rgba(255,255,255,0.45); margin-top:8px; letter-spacing:0.1em; text-transform:uppercase; line-height:1.6; }

    /* ── SECTION: FAQs ──────────────────────────────────────── */
    #faqs { background:var(--black); }
    .faq-item { border-bottom:1px solid rgba(255,255,255,0.08); }
    .faq-btn { width:100%; background:none; border:none; display:flex; align-items:center; justify-content:space-between; padding:26px 0; cursor:pointer; text-align:left; font-family:var(--serif); font-size:1.125rem; color:var(--white); gap:16px; }
    .faq-ic { flex-shrink:0; width:28px; height:28px; border:1px solid rgba(255,255,255,0.25); border-radius:50%; display:flex; align-items:center; justify-content:center; color:rgba(255,255,255,0.5); font-size:1rem; font-style:normal; transition:transform .3s, background .3s, border-color .3s, color .3s; }
    .faq-btn.open .faq-ic { transform:rotate(45deg); background:var(--gold); border-color:var(--gold); color:var(--black); }
    .faq-ans { max-height:0; overflow:hidden; transition:max-height .45s ease; }
    .faq-ans p { padding-bottom:28px; font-size:0.9375rem; line-height:1.85; color:rgba(255,255,255,0.55); }
    .faq-item.open .faq-ans { max-height:320px; }

    /* ── SECTION: CONTACTO ──────────────────────────────────── */
    #contacto { background:var(--charcoal); }
    .contacto-grid { display:grid; grid-template-columns:1fr 1fr; gap:100px; align-items:start; }
    .contact-info-item { display:flex; align-items:flex-start; gap:20px; }
    .contact-icon { width:1px; height:32px; background:var(--gold); flex-shrink:0; margin-top:4px; }
    .form-field { display:flex; flex-direction:column; gap:8px; }
    .form-label { font-size:0.625rem; font-weight:500; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.45); }
    .form-input { width:100%; background:transparent; border:none; border-bottom:1px solid rgba(255,255,255,0.15); padding:12px 0; color:var(--white); font-family:var(--sans); font-size:0.9375rem; outline:none; transition:border-color .25s; }
    .form-input:focus { border-color:var(--gold); }
    .form-input::placeholder { color:rgba(255,255,255,0.25); }

    /* ── SECTION DIVIDERS ──────────────────────────────────── */
    .section-divider {
      border: none;
      height: 1px;
      background: linear-gradient(to right, transparent 0%, rgba(154,123,79,0.4) 20%, rgba(154,123,79,0.7) 50%, rgba(154,123,79,0.4) 80%, transparent 100%);
      margin: 0;
    }

    /* ── FOOTER ────────────────────────────────────────────── */
    footer { background:var(--black); padding:80px 0 40px; border-top:1px solid rgba(255,255,255,0.07); }
    .footer-grid { display:grid; grid-template-columns:280px 1fr 1fr; gap:60px; margin-bottom:64px; }
    .footer-brand .logo { display:block; color:var(--white); font-size:1.4rem; margin-bottom:16px; }
    .footer-brand p { font-size:0.8125rem; color:rgba(255,255,255,0.35); line-height:1.75; max-width:210px; }
    .footer-col h4 { font-family:var(--serif); font-style:italic; font-size:1rem; color:rgba(255,255,255,0.5); font-weight:300; margin-bottom:24px; }
    .footer-col a { display:block; font-size:0.6875rem; font-weight:500; letter-spacing:0.16em; text-transform:uppercase; color:rgba(255,255,255,0.45); margin-bottom:16px; transition:color .2s; }
    .footer-col a:hover { color:var(--white); }
    .footer-bottom { border-top:1px solid rgba(255,255,255,0.06); padding-top:28px; display:flex; justify-content:space-between; align-items:center; font-size:0.6875rem; letter-spacing:0.08em; color:rgba(255,255,255,0.22); }

    /* ── RESPONSIVE ─────────────────────────────────────────── */
    @media (max-width: 900px) {
      .process-grid { grid-template-columns:1fr; }
      .process-card { aspect-ratio:16/9; }
      .porque-grid { grid-template-columns:1fr; }
      .pricing-grid { grid-template-columns:1fr; }
      .historia-grid { grid-template-columns:1fr; gap:48px; }
      .historia-img { height:360px; }
      .contacto-grid { grid-template-columns:1fr; gap:60px; }
      .footer-grid { grid-template-columns:1fr; gap:40px; }
      .footer-bottom { flex-direction:column; gap:8px; text-align:center; }
      .hero-copy h1 { font-size:clamp(2.5rem,9vw,5rem); }
      .hero-topbar { display:none; }
    }
    @media (max-width: 600px) {
      .container { padding:0 24px; }
      nav { padding:0 24px; }
      .hero-copy { padding:0 24px 60px; }
      .hero-scroll { display:none; }
    }
  </style>
</head>
<body>

  <!-- Header -->
  <header id="header">
    <nav>
      <a href="#" class="logo">Flou<em>x</em></a>
      <ul class="nav-links">
        <li><a href="#como">Cómo funciona</a></li>
        <li><a href="#porque">Por qué Floux</a></li>
        <li><a href="#precios">Precios</a></li>
        <li><a href="#historia">Nuestra historia</a></li>
        <li><a href="#faqs">FAQs</a></li>
        <li><a href="#contacto">Contacto</a></li>
        <li><a href="mailto:flouxaim@gmail.com?subject=Quiero una demostración de Floux" class="btn btn-primary">Ver demostración</a></li>
      </ul>
      <button class="burger" id="burger" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </nav>
    <div class="mobile-drawer" id="drawer">
      <a href="#como">Cómo funciona</a>
      <a href="#porque">Por qué Floux</a>
      <a href="#precios">Precios</a>
      <a href="#historia">Nuestra historia</a>
      <a href="#faqs">FAQs</a>
      <a href="#contacto">Contacto</a>
      <a href="mailto:flouxaim@gmail.com?subject=Quiero una demostración de Floux" class="btn btn-primary">Ver demostración</a>
    </div>
  </header>

  <main>

    <!-- Hero -->
    <section id="hero">
      <div class="hero-img">
