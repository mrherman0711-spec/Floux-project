            <div class="form-field">
              <label class="form-label">Nombre del salón</label>
              <input type="text" id="f-salon" required placeholder="Nombre de tu centro o salón" class="form-input" />
            </div>
            <div class="form-field">
              <label class="form-label">Teléfono o WhatsApp</label>
              <input type="tel" id="f-tel" required placeholder="+34 600 000 000" class="form-input" />
            </div>
